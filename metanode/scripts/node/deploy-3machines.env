#!/bin/bash
# ╔═══════════════════════════════════════════════════════════════════╗
# ║  MULTI-SERVER DEPLOYMENT CONFIG — 3 MACHINES TEST CLUSTER         ║
# ║                                                                   ║
# ║  Machines:                                                        ║
# ║    192.168.1.234  →  Node 0, Node 1  (máy chính / build machine) ║
# ║    192.168.1.233  →  Node 2                                       ║
# ║    192.168.1.231  →  Node 3                                       ║
# ║                                                                   ║
# ║  Usage:                                                           ║
# ║    ENV_FILE=deploy-3machines.env ./deploy_cluster.sh --all        ║
# ║                                                                   ║
# ║  Flow: Build locally (234) → Push binaries+configs → Start remote ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── SSH Config ──────────────────────────────────────────────────────
SSH_USER="abc"

# Authentication: "key" or "password"
SSH_AUTH="password"

# For key auth: SSH key path (leave empty for default ~/.ssh/id_rsa)
SSH_KEY=""

# For password auth: (requires sshpass installed)
SSH_PASSWORD="1234@abcd"

# SSH options
SSH_OPTS="-o StrictHostKeyChecking=no -o ConnectTimeout=10"

# ─── Server IPs ─────────────────────────────────────────────────────
SERVER_A="192.168.1.234"   # Node 0, Node 1  (máy build + deploy 2 node)
SERVER_B="192.168.1.233"   # Node 2
SERVER_C="192.168.1.231"   # Node 3

# ─── Node → Server Mapping ──────────────────────────────────────────
declare -A NODE_SERVER
NODE_SERVER[0]="$SERVER_A"    # Node 0 chạy trên máy 234
NODE_SERVER[1]="$SERVER_A"    # Node 1 chạy trên máy 234
NODE_SERVER[2]="$SERVER_B"    # Node 2 chạy trên máy 233
NODE_SERVER[3]="$SERVER_C"    # Node 3 chạy trên máy 231
NODE_SERVER[4]="$SERVER_C"    # Node 4 (Sync-Only) chạy trên máy 231

# ─── Local Source Paths (existing code on THIS machine: 192.168.1.234) ─────
LOCAL_CHAIN_DIR="/home/abc/nhat/con-chain-v2"
LOCAL_MTN_CONSENSUS="${LOCAL_CHAIN_DIR}/mtn-consensus"
LOCAL_MTN_SIMPLE="${LOCAL_CHAIN_DIR}/mtn-simple-2025"
LOCAL_METANODE="${LOCAL_MTN_CONSENSUS}/metanode"
LOCAL_GO_SIMPLE="${LOCAL_MTN_SIMPLE}/cmd/simple_chain"

# ─── Remote Deploy Paths (auto-created on each server) ──────────────
REMOTE_DEPLOY_DIR="/home/${SSH_USER}/nhat/con-chain-v2"
REMOTE_MTN_CONSENSUS="${REMOTE_DEPLOY_DIR}/mtn-consensus"
REMOTE_MTN_SIMPLE="${REMOTE_DEPLOY_DIR}/mtn-simple-2025"
REMOTE_METANODE="${REMOTE_MTN_CONSENSUS}/metanode"
REMOTE_SCRIPTS="${REMOTE_METANODE}/scripts/node"
REMOTE_GO_SIMPLE="${REMOTE_MTN_SIMPLE}/cmd/simple_chain"

# ─── Build Config ───────────────────────────────────────────────────
RUST_TOOLCHAIN="nightly"
GO_TOOLCHAIN="go1.23.5"
