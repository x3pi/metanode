package main

import (
	"encoding/hex"
	"encoding/json"
	"fmt"
	"math/big"
	"os"

	"github.com/ethereum/go-ethereum/common"
	"github.com/ethereum/go-ethereum/crypto"

	"github.com/meta-node-blockchain/meta-node/cmd/rpc-client/client-tcp/config"
	"github.com/meta-node-blockchain/meta-node/pkg/bls"
	p_common "github.com/meta-node-blockchain/meta-node/pkg/common"
	"github.com/meta-node-blockchain/meta-node/pkg/transaction"
)

type AccountInfo struct {
	Index      int    `json:"index"`
	PrivateKey string `json:"private_key"`
	Address    string `json:"address"`
	Registered bool   `json:"registered"`
	Funded     bool   `json:"funded"`
}

type Payload struct {
	Index   int    `json:"index"`
	TxBytes string `json:"tx_bytes"`
}

func main() {
	// Read Accounts
	data, err := os.ReadFile("../batch_account_setup/accounts.json")
	if err != nil {
		panic(fmt.Sprintf("Failed to read accounts: %v", err))
	}

	var accounts []AccountInfo
	if err := json.Unmarshal(data, &accounts); err != nil {
		panic(fmt.Sprintf("Failed to unmarshal accounts: %v", err))
	}

	// Read config to get network chain ID and original BLS key address to related addresses
	conf, err := config.LoadConfig("../batch_account_setup/config.json")
	if err != nil {
		panic(fmt.Sprintf("Error loading config: %v", err))
	}
	cConfig := conf.(*config.ClientConfig)

	relatedAddresses := []common.Address{
		bls.NewKeyPair(cConfig.PrivateKey()).Address(),
	}

	// SimpleStorage Deploy Bytecode (same as data.json)
	inputBytes := common.FromHex("")

	fmt.Printf("Generating payloads for %d accounts...\n", len(accounts))

	var payloads []Payload

	for i, acc := range accounts {
		privKeyBytes, err := hex.DecodeString(acc.PrivateKey)
		if err != nil {
			panic(fmt.Sprintf("Invalid private key at index %d", i))
		}
		ecdsaKey, err := crypto.ToECDSA(privKeyBytes)
		if err != nil {
			panic(fmt.Sprintf("Invalid ECDSA format at index %d", i))
		}

		nonce := uint64(1) // Nonce 1 is the first non-AccountSetting transaction
		amount := big.NewInt(0)

		deployData := transaction.NewDeployData(inputBytes, common.Address{})
		bData, err := deployData.Marshal()
		if err != nil {
			panic(fmt.Sprintf("Marshal deploy data failed: %v", err))
		}

		relBytes := make([][]byte, 1)
		relBytes[0] = relatedAddresses[0].Bytes()

		tx := transaction.NewTransaction(
			crypto.PubkeyToAddress(ecdsaKey.PublicKey),
			common.Address{}, // dest = 0x0
			amount,
			10000000, // maxGas
			1000000,  // maxGasFee
			0,        // maxTimeUse
			bData,
			relBytes,
			common.Hash{}, // lastDeviceKey
			common.Hash{}, // newDeviceKey
			nonce,
			cConfig.ChainId,
		)

		var pKey p_common.PrivateKey
		copy(pKey[:], cConfig.PrivateKey())
		tx.SetSign(pKey)

		txBytes, err := tx.Marshal()
		if err != nil {
			panic(fmt.Sprintf("Marshal signed TX failed: %v", err))
		}

		payloads = append(payloads, Payload{
			Index:   acc.Index,
			TxBytes: hex.EncodeToString(txBytes),
		})
	}

	outData, err := json.MarshalIndent(payloads, "", "  ")
	if err != nil {
		panic(fmt.Sprintf("Marshal payloads failed: %v", err))
	}

	err = os.WriteFile("tx_payloads.json", outData, 0644)
	if err != nil {
		panic(fmt.Sprintf("Write payloads file failed: %v", err))
	}

	fmt.Printf("✅ Saved %d offline payloads to tx_payloads.json\n", len(payloads))
}
